{
  "name": "@psmfd/pi-gh-identity-guard",
  "version": "0.1.1",
  "description": "Pi extension: blocks mutating gh and git push operations when the active GitHub identity is wrong for the target repo",
  "type": "module",
  "license": "MIT",
  "repository": "github:psmfd/pi-gh-identity-guard",
  "keywords": [
    "pi",
    "pi-extension"
  ],
  "pi": {
    "extensions": [
      "./index.ts"
    ]
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "tsx --test test/*.test.ts"
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": ">=0.75"
  },
  "devDependencies": {
    "@earendil-works/pi-coding-agent": "0.79.3",
    "@types/node": "^25.9.3",
    "tsx": "^4.19.2",
    "typescript": "^6.0.3"
  }
}
